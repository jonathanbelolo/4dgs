+__device__ __inline__ void trace_ray_cuvol_backward_sequential(
+        const PackedSparseGridSpec& __restrict__ grid,
+        const float* __restrict__ grad_output,
+        const float* __restrict__ color_cache,
+        SingleRaySpec& __restrict__ ray,
+        const RenderOptions& __restrict__ opt,
+        uint32_t lane_id,
+        const float* __restrict__ sphfunc_val,
+        float* __restrict__ grad_sphfunc_val,
+        float log_transmit_in,
+        float beta_loss,
+        float sparsity_loss,
+        PackedGridOutputGrads& __restrict__ grads,
+        float* __restrict__ accum_out,
+        float* __restrict__ log_transmit_out
+        ) {
+    // Sequential color channel backward path for basis_dim > 10.
+    // All 32 warp threads stay alive; inactive threads contribute 0.
+    const bool is_active = (lane_id < static_cast<uint32_t>(grid.basis_dim));
+
+    float accum = fmaf(color_cache[0], grad_output[0],
+                      fmaf(color_cache[1], grad_output[1],
+                           color_cache[2] * grad_output[2]));
+
+    if (ray.tmin > ray.tmax) {
+        if (accum_out != nullptr && lane_id == 0) { *accum_out = accum; }
+        if (log_transmit_out != nullptr && lane_id == 0) { *log_transmit_out = 0.f; }
+        return;
+    }
+
+    if (beta_loss > 0.f) {
+        const float transmit_in = _EXP(log_transmit_in);
+        beta_loss *= (1 - transmit_in / (1 - transmit_in + 1e-3));
+        accum += beta_loss;
+    }
+
+    float t = ray.tmin;
+    float log_transmit = 0.f;
+
+    while (t <= ray.tmax) {
+#pragma unroll 3
+        for (int j = 0; j < 3; ++j) {
+            ray.pos[j] = fmaf(t, ray.dir[j], ray.origin[j]);
+            ray.pos[j] = min(max(ray.pos[j], 0.f), grid.size[j] - 1.f);
+            ray.l[j] = min(static_cast<int32_t>(ray.pos[j]), grid.size[j] - 2);
+            ray.pos[j] -= static_cast<float>(ray.l[j]);
+        }
+        const float skip = compute_skip_dist(ray,
+                       grid.links, grid.stride_x,
+                       grid.size[2], 0);
+        if (skip >= opt.step_size) {
+            t += ceilf(skip / opt.step_size) * opt.step_size;
+            continue;
+        }
+
+        float sigma = trilerp_cuvol_one(
+                grid.links, grid.density_data,
+                grid.stride_x, grid.size[2],
+                1, ray.l, ray.pos, 0);
+        if (opt.last_sample_opaque && t + opt.step_size > ray.tmax) {
+            ray.world_step = 1e9;
+        }
+
+        if (sigma > opt.sigma_thresh) {
+            const float pcnt = ray.world_step * sigma;
+            const float weight = _EXP(log_transmit) * (1.f - _EXP(-pcnt));
+            log_transmit -= pcnt;
+
+            // Compute color totals and gradients per channel sequentially
+            float total_color_dot_gout = 0.f;
+
+            for (int color_ch = 0; color_ch < 3; ++color_ch) {
+                float lane_color = 0.f;
+                float contrib = 0.f;
+                if (is_active) {
+                    lane_color = trilerp_cuvol_one(
+                        grid.links, grid.sh_data,
+                        grid.stride_x, grid.size[2],
+                        grid.sh_data_dim,
+                        ray.l, ray.pos,
+                        color_ch * grid.basis_dim + lane_id);
+                    contrib = lane_color * sphfunc_val[lane_id];
+                }
+                // Full warp reduce
+                for (int offset = 16; offset > 0; offset >>= 1) {
+                    contrib += __shfl_down_sync(0xFFFFFFFF, contrib, offset);
+                }
+                // Broadcast color total to all threads
+                float color_total_raw = __shfl_sync(0xFFFFFFFF, contrib, 0) + 0.5f;
+                float color_total = fmaxf(color_total_raw, 0.f);
+                float color_in_01 = (color_total == color_total_raw) ? 1.f : 0.f;
+
+                total_color_dot_gout += color_total * grad_output[color_ch];
+
+                // SH coefficient gradient
+                float grad_common = weight * color_in_01 * grad_output[color_ch];
+                if (is_active) {
+                    float curr_grad_color = sphfunc_val[lane_id] * grad_common;
+                    trilerp_backward_cuvol_one(grid.links, grads.grad_sh_out,
+                            grid.stride_x, grid.size[2],
+                            grid.sh_data_dim,
+                            ray.l, ray.pos,
+                            curr_grad_color,
+                            color_ch * grid.basis_dim + lane_id);
+
+                    // SH basis gradient (for non-SH basis types)
+                    if (grid.basis_type != BASIS_TYPE_SH) {
+                        grad_sphfunc_val[lane_id] += lane_color * grad_common;
+                    }
+                }
+            }
+
+            accum -= weight * total_color_dot_gout;
+            float curr_grad_sigma = ray.world_step * (
+                    total_color_dot_gout * _EXP(log_transmit) - accum);
+            if (sparsity_loss > 0.f) {
+                curr_grad_sigma += sparsity_loss * (4 * sigma / (1 + 2 * (sigma * sigma)));
+            }
+            if (lane_id == 0) {
+                trilerp_backward_cuvol_one_density(
+                        grid.links,
+                        grads.grad_density_out,
+                        grads.mask_out,
+                        grid.stride_x,
+                        grid.size[2],
+                        ray.l, ray.pos, curr_grad_sigma);
+            }
+            if (_EXP(log_transmit) < opt.stop_thresh) {
+                break;
+            }
+        }
+        t += opt.step_size;
+    }
+    if (lane_id == 0) {
+        if (accum_out != nullptr) {
+            accum -= beta_loss;
+            *accum_out = accum;
+        }
+        if (log_transmit_out != nullptr) { *log_transmit_out = log_transmit; }
+    }
+}
