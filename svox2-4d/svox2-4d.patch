+    ):
+        """Sparse-to-sparse upsample: only materializes occupied region.
+
+        Unlike resample(), which generates all R_out^3 points, this method:
+        1. Upsamples the old occupancy mask (dilated) to new resolution
+        2. Only queries points in the occupied region
+        3. Thresholds and builds new sparse grid
+
+        Memory: O(occupied_voxels) instead of O(R^3).
+        For 520->1032 with ~5% occupancy: ~50M pts instead of 1.1B.
+
+        Args:
+            new_reso: target resolution (isotropic)
+            sigma_thresh: density threshold for keeping voxels
+            dilate: dilation iterations on occupancy mask
+            accelerate: if True, rebuilds distance transform after upsample
+        """
+        with torch.no_grad():
+            device = self.links.device
+            curr_reso = list(self.links.shape)
+            reso = [new_reso] * 3
+
+            # --- Step 1: Build dilated occupancy mask at OLD resolution ---
+            occ_mask = (self.links >= 0)  # (Rx, Ry, Rz) bool
+            if dilate > 0:
+                for _ in range(dilate):
+                    occ_mask = _C.dilate(occ_mask)
+
+            # --- Step 2: Upsample occupancy mask to NEW resolution ---
+            # Each old voxel maps to a block of (scale x scale x scale) new voxels
+            scale = [reso[i] / curr_reso[i] for i in range(3)]
+            # Use nearest-neighbor upsample of the mask
+            occ_float = occ_mask.float().unsqueeze(0).unsqueeze(0)  # (1,1,Rx,Ry,Rz)
+            occ_up = torch.nn.functional.interpolate(
+                occ_float,
+                size=reso,
+                mode="nearest",
