+__device__ __inline__ void trace_ray_cuvol_sequential(
+        const PackedSparseGridSpec& __restrict__ grid,
+        SingleRaySpec& __restrict__ ray,
+        const RenderOptions& __restrict__ opt,
+        uint32_t lane_id,
+        float* __restrict__ sphfunc_val,
+        float* __restrict__ out,
+        float* __restrict__ out_log_transmit) {
+    // Sequential color channel path for basis_dim > 10.
+    // All 32 warp threads stay alive; threads with lane_id >= basis_dim
+    // contribute 0 to the reduction.
+    const bool is_active = (lane_id < static_cast<uint32_t>(grid.basis_dim));
+
+    if (ray.tmin > ray.tmax) {
+        if (lane_id < 3)
+            out[lane_id] = (grid.background_nlayers == 0) ? opt.background_brightness : 0.f;
+        if (out_log_transmit != nullptr && lane_id == 0)
+            *out_log_transmit = 0.f;
+        return;
+    }
+
+    float t = ray.tmin;
+    float outv[3] = {0.f, 0.f, 0.f};
+    float log_transmit = 0.f;
+
+    while (t <= ray.tmax) {
+#pragma unroll 3
+        for (int j = 0; j < 3; ++j) {
+            ray.pos[j] = fmaf(t, ray.dir[j], ray.origin[j]);
+            ray.pos[j] = min(max(ray.pos[j], 0.f), grid.size[j] - 1.f);
+            ray.l[j] = min(static_cast<int32_t>(ray.pos[j]), grid.size[j] - 2);
+            ray.pos[j] -= static_cast<float>(ray.l[j]);
+        }
+
+        const float skip = compute_skip_dist(ray,
+                       grid.links, grid.stride_x,
+                       grid.size[2], 0);
+        if (skip >= opt.step_size) {
+            t += ceilf(skip / opt.step_size) * opt.step_size;
+            continue;
+        }
+        float sigma = trilerp_cuvol_one(
+                grid.links, grid.density_data,
+                grid.stride_x, grid.size[2],
+                1, ray.l, ray.pos, 0);
+        if (opt.last_sample_opaque && t + opt.step_size > ray.tmax) {
+            ray.world_step = 1e9;
+        }
+
+        if (sigma > opt.sigma_thresh) {
+            const float pcnt = ray.world_step * sigma;
+            const float weight = _EXP(log_transmit) * (1.f - _EXP(-pcnt));
+            log_transmit -= pcnt;
+
+            // Process each color channel sequentially
+            for (int color_ch = 0; color_ch < 3; ++color_ch) {
+                float contrib = 0.f;
+                if (is_active) {
+                    float lane_color = trilerp_cuvol_one(
+                        grid.links, grid.sh_data,
+                        grid.stride_x, grid.size[2],
+                        grid.sh_data_dim,
+                        ray.l, ray.pos,
+                        color_ch * grid.basis_dim + lane_id);
+                    contrib = lane_color * sphfunc_val[lane_id];
+                }
+                // Full warp reduce (all 32 threads; inactive contribute 0)
+                for (int offset = 16; offset > 0; offset >>= 1) {
+                    contrib += __shfl_down_sync(0xFFFFFFFF, contrib, offset);
+                }
+                if (lane_id == 0) {
+                    outv[color_ch] += weight * fmaxf(contrib + 0.5f, 0.f);
+                }
+            }
+
+            if (_EXP(log_transmit) < opt.stop_thresh) {
+                log_transmit = -1e3f;
+                break;
+            }
+        }
+        t += opt.step_size;
+    }
+
+    if (lane_id == 0) {
+        if (grid.background_nlayers == 0) {
+            float bg = _EXP(log_transmit) * opt.background_brightness;
+            outv[0] += bg; outv[1] += bg; outv[2] += bg;
+        }
+        out[0] = outv[0];
+        out[1] = outv[1];
+        out[2] = outv[2];
+        if (out_log_transmit != nullptr) {
+            *out_log_transmit = log_transmit;
+        }
+    }
+}
