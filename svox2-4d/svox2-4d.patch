+    def compute_lr_weights(self, min_weight: float = 0.1, max_weight: float = 3.0):
+        """Compute per-voxel LR multiplier from hit counts.
+
+        Under-sampled voxels get higher LR, over-sampled get lower.
+        Formula: w = sqrt(mean_hits / max(hits, 1)), clamped to [min, max].
+        """
